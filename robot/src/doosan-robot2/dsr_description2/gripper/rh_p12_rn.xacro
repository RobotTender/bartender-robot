<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="rh_p12_rn" params="parent prefix base_xyz:='0 0 0' base_rpy:='0 0 0'">

    <!-- Gripper Base -->
    <link name="${prefix}rh_p12_rn_base_link">
      <visual>
        <origin xyz="0 0 0.03" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.04" length="0.06"/>
        </geometry>
        <material name="dark_grey"><color rgba="0.2 0.2 0.2 1"/></material>
      </visual>
      <collision>
        <origin xyz="0 0 0.03" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.04" length="0.06"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.03" rpy="0 0 0"/>
        <mass value="0.5"/>
        <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0004"/>
      </inertial>
    </link>

    <!-- Left Finger -->
    <link name="${prefix}rh_p12_rn_left_finger">
      <visual>
        <origin xyz="0.01 0 0.04" rpy="0 0 0"/>
        <geometry>
          <box size="0.01 0.02 0.08"/>
        </geometry>
        <material name="light_grey"><color rgba="0.7 0.7 0.7 1"/></material>
      </visual>
      <collision>
        <origin xyz="0.01 0 0.04" rpy="0 0 0"/>
        <geometry>
          <box size="0.01 0.02 0.08"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.00001"/>
      </inertial>
    </link>

    <!-- Right Finger -->
    <link name="${prefix}rh_p12_rn_right_finger">
      <visual>
        <origin xyz="-0.01 0 0.04" rpy="0 0 0"/>
        <geometry>
          <box size="0.01 0.02 0.08"/>
        </geometry>
        <material name="light_grey"><color rgba="0.7 0.7 0.7 1"/></material>
      </visual>
      <collision>
        <origin xyz="-0.01 0 0.04" rpy="0 0 0"/>
        <geometry>
          <box size="0.01 0.02 0.08"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.00001"/>
      </inertial>
    </link>

    <!-- TCP -->
    <link name="${prefix}gripper_tcp">
      <inertial>
        <mass value="0.0001"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="1e-8" iyy="1e-8" izz="1e-8" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <joint name="${prefix}rh_p12_rn_base_joint" type="fixed">
      <parent link="${parent}"/>
      <child  link="${prefix}rh_p12_rn_base_link"/>
      <origin xyz="${base_xyz}" rpy="${base_rpy}"/>
    </joint>

    <joint name="${prefix}rh_p12_rn_left_finger_joint" type="prismatic">
      <parent link="${prefix}rh_p12_rn_base_link"/>
      <child  link="${prefix}rh_p12_rn_left_finger"/>
      <axis xyz="1 0 0"/>
      <origin xyz="0.01 0 0.06" rpy="0 0 0"/>
      <limit lower="0.0" upper="0.05" velocity="0.1" effort="100"/>
    </joint>

    <joint name="${prefix}rh_p12_rn_right_finger_joint" type="prismatic">
      <parent link="${prefix}rh_p12_rn_base_link"/>
      <child  link="${prefix}rh_p12_rn_right_finger"/>
      <axis xyz="-1 0 0"/>
      <origin xyz="-0.01 0 0.06" rpy="0 0 0"/>
      <limit lower="0.0" upper="0.05" velocity="0.1" effort="100"/>
      <mimic joint="${prefix}rh_p12_rn_left_finger_joint"/>
    </joint>

    <joint name="${prefix}gripper_tcp_joint" type="fixed">
      <parent link="${prefix}rh_p12_rn_base_link"/>
      <child  link="${prefix}gripper_tcp"/>
      <origin xyz="0 0 0.10" rpy="0 0 0"/>
    </joint>

  </xacro:macro>

</robot>
