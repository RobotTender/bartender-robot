+// [TEAM2 SYS 2026-02-19 12:36:41 JST] Centralized publish helper used by monitoring callbacks after cache updates.
+void PublishRobotStateFromCache()
+{
+    if (instance == nullptr || instance->robot_state_pub_ == nullptr) return;
+    if (0 == instance->robot_state_pub_.use_count()) return;
+
+    dsr_msgs2::msg::RobotState msg;
+    FillRobotStateMsgFromCache(msg);
+    instance->robot_state_pub_->publish(msg);
+}
+
+void PublishRobotStateRtFromRt()
+{
+    if (instance == nullptr || instance->robot_state_rt_pub_ == nullptr) return;
+    if (0 == instance->robot_state_rt_pub_.use_count()) return;
+
+    LPRT_OUTPUT_DATA_LIST temp = Drfl->read_data_rt();
+    if (!temp) return;
+
+    dsr_msgs2::msg::RobotStateRt msg;
+    msg.time_stamp = temp->time_stamp;
+    msg.robot_mode = temp->robot_mode;
+    msg.robot_state = temp->robot_state;
+    msg.control_mode = temp->control_mode;
+    for (size_t i = 0; i < 6; ++i) {
+        msg.actual_joint_position[i] = temp->actual_joint_position[i];
+        msg.actual_tcp_position[i] = temp->actual_tcp_position[i];
+        msg.actual_flange_position[i] = temp->actual_flange_position[i];
+    }
+    instance->robot_state_rt_pub_->publish(msg);
+}
