+// [TEAM2 SYS 2026-02-19 12:36:41 JST] Added enum-style state name mapping for RobotState.msg.robot_state_str.
+// The original helper above returns human-readable strings with numeric prefixes.
+const char* GetRobotStateName(int nState)
+{
+    switch(nState)
+    {
+    case STATE_INITIALIZING:    return "STATE_INITIALIZING";
+    case STATE_STANDBY:         return "STATE_STANDBY";
+    case STATE_MOVING:          return "STATE_MOVING";
+    case STATE_SAFE_OFF:        return "STATE_SAFE_OFF";
+    case STATE_TEACHING:        return "STATE_TEACHING";
+    case STATE_SAFE_STOP:       return "STATE_SAFE_STOP";
+    case STATE_EMERGENCY_STOP:  return "STATE_EMERGENCY_STOP";
+    case STATE_HOMMING:         return "STATE_HOMMING";
+    case STATE_RECOVERY:        return "STATE_RECOVERY";
+    case STATE_SAFE_STOP2:      return "STATE_SAFE_STOP2";
+    case STATE_SAFE_OFF2:       return "STATE_SAFE_OFF2";
+    case STATE_RESERVED1:       return "STATE_RESERVED1";
+    case STATE_RESERVED2:       return "STATE_RESERVED2";
+    case STATE_RESERVED3:       return "STATE_RESERVED3";
+    case STATE_RESERVED4:       return "STATE_RESERVED4";
+    case STATE_NOT_READY:       return "STATE_NOT_READY";
+    default:                    return "STATE_UNKNOWN";
+    }
+}
